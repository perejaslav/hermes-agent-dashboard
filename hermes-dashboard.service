[Unit]
Description=Hermes Agent Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__HERMES_USER__
Group=__HERMES_GROUP__
WorkingDirectory=__HERMES_HOME__
Environment=HOME=__HERMES_HOME__
ExecStart=__HERMES_PYTHON__ __HERMES_HOME__/hermes-dashboard.py --port 8420 --bind 0.0.0.0 --poll 5
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
